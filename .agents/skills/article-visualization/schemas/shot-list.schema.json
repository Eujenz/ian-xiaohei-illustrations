{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["article_slug", "shots"],
  "additionalProperties": true,
  "properties": {
    "article_slug": {"type": "string"},
    "shots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "placement", "source_heading", "source_excerpt", "anchor_type", "structure_type", "theme", "core_idea", "metaphor", "character_action", "overlay_labels"],
        "properties": {
          "id": {"type": "string"},
          "placement": {"type": "string"},
          "source_heading": {"type": "string"},
          "source_excerpt": {"type": "string"},
          "anchor_type": {"type": "string"},
          "structure_type": {"enum": ["workflow", "system_local", "before_after", "character_state", "concept_metaphor", "method_layering", "map_route", "comic_sequence"]},
          "theme": {"type": "string"},
          "core_idea": {"type": "string"},
          "metaphor": {"type": "string"},
          "character_action": {"type": "string"},
          "overlay_labels": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["id", "text", "anchor", "placeholder", "max_chars"],
              "properties": {
                "id": {"type": "string"},
                "text": {"type": "string"},
                "anchor": {"type": "string"},
                "placeholder": {"type": "string"},
                "max_chars": {"type": "integer", "minimum": 1}
              }
            }
          }
        }
      }
    }
  }
}
