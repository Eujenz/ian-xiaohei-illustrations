{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["shot_id", "canvas", "labels"],
  "additionalProperties": false,
  "properties": {
    "shot_id": {"type": "string"},
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": true,
      "properties": {
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "target_ratio": {"type": "string"}
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "x", "y", "box_width", "box_height", "font_size"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "text": {"type": "string"},
          "x": {"type": "integer"},
          "y": {"type": "integer"},
          "box_width": {"type": "integer", "minimum": 1},
          "box_height": {"type": "integer", "minimum": 1},
          "font_size": {"type": "integer", "minimum": 1},
          "anchor": {"type": "string"},
          "placeholder": {"type": "string"},
          "rotation": {"type": "number"},
          "align": {"enum": ["left", "center", "right"]},
          "color": {"type": "string"},
          "stroke_width": {"type": "number"},
          "style": {"enum": ["handwritten_note", "callout", "arrow_label", "plain"]},
          "max_chars": {"type": "integer", "minimum": 1}
        }
      }
    }
  }
}
